{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gitshow-realtime",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "durable_objects": {
    "bindings": [
      {
        "name": "SCAN_LIVE_DO",
        "class_name": "ScanLiveDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ScanLiveDO"]
    }
  ]
}
