{
  "name": "@gitshow/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitShow web app — Next 16 on Cloudflare Workers via OpenNext, AI Elements UI, D1 + R2 bindings.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "d1:local:init": "for f in ../../migrations/*.sql; do echo \"== $f ==\"; wrangler d1 execute gitshow-db --local --file=\"$f\"; done",
    "d1:local:query": "wrangler d1 execute gitshow-db --local --command"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.0",
    "@cloudflare/puppeteer": "^1.1.0",
    "@dodopayments/better-auth": "^1.6.2",
    "@gitshow/shared": "workspace:*",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "ai": "^5.0.0",
    "better-auth": "^1.6.5",
    "better-auth-cloudflare": "^0.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dodopayments": "^2.28.2",
    "lucide-react": "^0.475.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "postprocessing": "^6.38.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.1",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.1",
    "three": "^0.181.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@opennextjs/cloudflare": "^1.19.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.181.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0"
  }
}
