# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── Cloud integrations (set GITSHOW_CLOUD_MODE=1 to enable) ──
# When unset, the worker runs in local-CLI mode: writes to ./profiles, no R2, no D1.
GITSHOW_CLOUD_MODE=

CF_ACCOUNT_ID=
CF_API_TOKEN=

R2_BUCKET_NAME=gitshow-scans
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

D1_DATABASE_ID=

# ── Fly (only needed for local smoke tests + the web app's spawn endpoint) ──
FLY_API_TOKEN=
FLY_APP_NAME=gitshow-worker
FLY_REGION=iad
FLY_WORKER_IMAGE=registry.fly.io/gitshow-worker:latest

# ── Per-scan, injected by Fly Machines API at create-time in production ──
# SCAN_ID=
# HANDLE=
# GH_TOKEN=
