# OpenRouter API key — used for Kimi (judge), Sonnet (ranker), Opus
# (KG merger + hero), Gemini 3 Flash Preview (per-repo evidence,
# LinkedIn Tier 2, KG-level person report). Required.
OPENROUTER_API_KEY=sk-or-v1-...

# TinyFish — real-browser web fetch + agent (https://docs.tinyfish.ai/agent-api).
# Used by LinkedIn fetcher Tier 1. Same key works for both fetch and
# agent endpoints. Get one at agent.tinyfish.ai/api-keys.
TINYFISH_API_KEY=

# ProxyCurl / EnrichLayer — paid LinkedIn API. Used as Tier 0 of the
# LinkedIn fetch chain. Optional; chain falls through to TinyFish Agent
# (Tier 1) and Gemini grounded (Tier 2) when missing.
PROXYCURL_API_KEY=

# PostHog — observability for the AI pipeline. Worker streams stage
# events + $ai_generation events for every LLM call. Get the project
# key at app.posthog.com → Project settings → Project API key.
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Cloud integrations (set GITSHOW_CLOUD_MODE=1 to enable) ──
# When unset, the worker runs in local-CLI mode: writes to ./profiles, no R2, no D1.
GITSHOW_CLOUD_MODE=

CF_ACCOUNT_ID=
CF_API_TOKEN=

R2_BUCKET_NAME=gitshow-scans
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

D1_DATABASE_ID=

# ── Fly (only needed for local smoke tests + the web app's spawn endpoint) ──
FLY_API_TOKEN=
FLY_APP_NAME=gitshow-worker
FLY_REGION=iad
FLY_WORKER_IMAGE=registry.fly.io/gitshow-worker:latest

# ── Per-scan, injected by Fly Machines API at create-time in production ──
# SCAN_ID=
# HANDLE=
# GH_TOKEN=
