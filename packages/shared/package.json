    "./kg": "./src/kg/index.ts",
    "./skill-icon-slugs": "./src/skill-icon-slugs.ts",
    "./events": "./src/events.ts",
    "./phase-copy": "./src/phase-copy.ts",
    "./eta": "./src/eta.ts",
    "./util": "./src/util.ts",
    "./cloud/d1": "./src/cloud/d1.ts",
    "./cloud/r2": "./src/cloud/r2.ts",
    "./cloud/fly": "./src/cloud/fly.ts",
    "./cloud/tinyfish": "./src/cloud/tinyfish.ts",
    "./cloud/tinyfish-agent": "./src/cloud/tinyfish-agent.ts",
    "./cloud/gemini-grounded": "./src/cloud/gemini-grounded.ts",
