{
  "name": "gitshow",
  "version": "0.1.0",
  "private": true,
  "description": "GitShow — AI-generated engineering portfolios from git history",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "profile": "bun --filter @gitshow/worker profile",
    "typecheck": "bun --filter '*' typecheck",
    "dev:web": "bun --filter @gitshow/web dev",
    "build:web": "bun --filter @gitshow/web build",
    "deploy:web": "bun --filter @gitshow/web deploy",
    "deploy:realtime": "bun --filter @gitshow/realtime deploy"
  }
}
